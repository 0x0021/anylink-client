<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Rokae VPN</Name>
    <Version>1.0</Version>
    <Title>Rokae VPN</Title>
    <Publisher>https://office.i.rokae.com:5443</Publisher>
    <ProductUrl>https://office.i.rokae.com:5443</ProductUrl>
    <InstallerWindowIcon>anylink64.png</InstallerWindowIcon>
    <InstallerApplicationIcon>anylink</InstallerApplicationIcon>
    <StartMenuDir>Rokae VPN</StartMenuDir>
    <TargetDir>@ApplicationsDir@/</TargetDir>
    <RemoveTargetDir>true</RemoveTargetDir>
    <WizardShowPageList>false</WizardShowPageList>
    <SupportsModify>false</SupportsModify>
    <RepositorySettingsPageVisible>false</RepositorySettingsPageVisible>
    <MaintenanceToolName>uninstall</MaintenanceToolName>
    <PersistentLocalCache>false</PersistentLocalCache>
    <ControlScript>controller.js</ControlScript>
    <DisableCommandLineInterface>true</DisableCommandLineInterface>
    <DisableAuthorizationFallback>true</DisableAuthorizationFallback>
    <SaveDefaultRepositories>false</SaveDefaultRepositories>
</Installer>
